<section class="py-24 bg-slate-50 border-t border-slate-200/60">

  <div class="max-w-6xl mx-auto px-6">

    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 tracking-tight mb-4">
        Accesos rápidos
      </h2>
      <p class="text-slate-500 text-lg max-w-xl mx-auto">
        Gestioná tus turnos, consultá tus estudios de forma digital o comunicate con administración.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8" data-aos="fade-up">
      
      <a
        href="https://sistemas.sanjoseve.com.ar/Turnos/"
        class="group bg-white rounded-2xl p-8 border border-slate-200/80 shadow-sm hover:shadow-xl hover:border-blue-200 hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between"
      >
        <div>
          <div class="w-12 h-12 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center mb-6 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-800 mb-3 group-hover:text-blue-700 transition-colors">
            Turnos Online
          </h3>
          <p class="text-slate-500 leading-relaxed mb-6">
            Reservá, reprogramá o cancelá tus turnos médicos de forma autónoma.
          </p>
        </div>
        <span class="text-blue-600 font-bold inline-flex items-center gap-2 group-hover:gap-4 transition-all text-sm uppercase tracking-wider">
          Acceder <span class="text-base">→</span>
        </span>
      </a>

      <div
        id="openStudiesModal"
        class="group bg-white rounded-2xl p-8 border border-slate-200/80 shadow-sm hover:shadow-xl hover:border-blue-200 hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between cursor-pointer"
      >
        <div>
          <div class="w-12 h-12 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center mb-6 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-800 mb-3 group-hover:text-blue-700 transition-colors">
            Mis Estudios
          </h3>
          <p class="text-slate-500 leading-relaxed mb-6">
            Visualizá y descargá de manera segura tus informes y resultados médicos.
          </p>
        </div>
        <span class="text-blue-600 font-bold inline-flex items-center gap-2 group-hover:gap-4 transition-all text-sm uppercase tracking-wider">
          Acceder <span class="text-base">→</span>
        </span>
      </div>
    </div>

  </div>

  <div
    id="studiesModal"
    class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm hidden items-center justify-center z-50 p-4 transition-opacity duration-300"
  >
    <div class="bg-white rounded-2xl p-8 w-full max-w-md shadow-2xl border border-slate-100 transform transition-transform duration-300 scale-100">

      <div class="flex items-center justify-between mb-6 pb-4 border-b border-slate-100">
        <div>
          <h3 class="text-2xl font-bold text-slate-900">
            Mis Estudios
          </h3>
          <p class="text-xs text-slate-400 mt-0.5">Seleccioná el portal correspondiente</p>
        </div>

        <button
          id="closeStudiesModal"
          class="w-8 h-8 rounded-full bg-slate-50 hover:bg-slate-100 text-slate-400 hover:text-slate-800 flex items-center justify-center transition-colors text-xl font-medium"
        >
          ✕
        </button>
      </div>

      <div class="flex flex-col gap-3.5">

        <a
          href="https://estudios.openimage.com.ar/GestionClinicas/portal.jsp"
          target="_blank"
          class="group flex items-center justify-between bg-blue-600 hover:bg-blue-700 text-white px-5 py-4 rounded-xl font-semibold transition-all shadow-sm hover:shadow-md"
        >
          <div class="flex flex-col text-left">
            <span>Portal Open Image</span>
            <span class="text-xs font-normal text-blue-200/90">Imágenes y alta complejidad</span>
          </div>
          <span class="transform group-hover:translate-x-1 transition-transform">→</span>
        </a>

        <a
          href="https://estudios.sanjoseve.com.ar"
          target="_blank"
          class="group flex items-center justify-between bg-slate-50 hover:bg-slate-100 border border-slate-200 text-slate-800 px-5 py-4 rounded-xl font-semibold transition-all"
        >
          <div class="flex flex-col text-left">
            <span>Estudios Gastro</span>
            <span class="text-xs font-normal text-slate-400">Gastroenterología</span>
          </div>
          <span class="text-slate-400 group-hover:text-slate-800 transform group-hover:translate-x-1 transition-transform">→</span>
        </a>

      </div>

    </div>
  </div>

  <script>
    const openBtn = document.getElementById('openStudiesModal');
    const modal = document.getElementById('studiesModal');
    const closeBtn = document.getElementById('closeStudiesModal');

    openBtn?.addEventListener('click', () => {
      modal?.classList.remove('hidden');
      modal?.classList.add('flex');
    });

    closeBtn?.addEventListener('click', () => {
      modal?.classList.add('hidden');
      modal?.classList.remove('flex');
    });

    modal?.addEventListener('click', (e) => {
      if (e.target === modal) {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      }
    });
  </script>

</section>