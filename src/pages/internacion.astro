---
import Layout from '../layouts/Layout.astro';
import * as ContenidoMarkdown from '../data/contenido-internacion.md';

const { Content, frontmatter } = ContenidoMarkdown;
---

<Layout title={`${frontmatter.title} - Sanatorio San José`}>

  <section class="bg-slate-900 text-white py-20 px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(59,130,246,0.1),transparent_50%)]"></div>
    <div class="max-w-3xl mx-auto relative z-10">
      <span class="inline-block bg-blue-500/20 text-blue-300 px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider mb-4">
        Guía al Paciente
      </span>
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4">
        {frontmatter.title}
      </h1>
      <p class="text-lg text-slate-300 leading-relaxed">
        {frontmatter.subtitle}
      </p>
    </div>
  </section>

  <section class="bg-white py-16 px-6">
    <div class="max-w-3xl mx-auto">
      
      <div class="mb-12 bg-slate-50 border border-slate-200 p-6 rounded-2xl flex flex-col md:flex-row md:items-center md:justify-between gap-5">
        <div class="flex items-start gap-3.5">
          <div class="text-2xl mt-0.5">📄</div>
          <div>
            <h3 class="text-base font-bold text-slate-900">Solicitud de Historia Clínica</h3>
            <p class="text-slate-500 text-sm mt-0.5">Puede realizar su pedido de documentación por correo:</p>
          </div>
        </div>
        <a 
          href={`mailto:${frontmatter.email}`}
          class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 px-5 rounded-xl transition text-center text-sm shadow-sm md:w-auto"
        >
          {frontmatter.email}
        </a>
      </div>

      <div class="
        [&_h2]:text-2xl [&_h2]:md:text-3xl [&_h2]:font-bold [&_h2]:text-slate-900 [&_h2]:tracking-tight [&_h2]:border-b [&_h2]:border-slate-200 [&_h2]:pb-3 [&_h2]:mt-12 [&_h2]:mb-6
        [&_h3]:text-base [&_h3]:font-bold [&_h3]:text-slate-400 [&_h3]:uppercase [&_h3]:tracking-wider [&_h3]:mt-6 [&_h3]:mb-4
        [&_p]:text-slate-650 [&_p]:text-base [&_p]:leading-relaxed [&_p]:mb-6
        [&_ul]:space-y-3 [&_ul]:mb-6 [&_ul]:list-disc [&_ul]:pl-5
        [&_li]:text-slate-650 [&_li]:text-base [&_li]:leading-relaxed
        [&_hr]:my-10 [&_hr]:border-slate-200
      ">
        
        <Content />
        
      </div>

    </div>
  </section>

</Layout>