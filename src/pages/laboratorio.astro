---
import Layout from '../layouts/Layout.astro';
import * as ContenidoLab from '../data/contenido-laboratorio.md';

const { Content, frontmatter } = ContenidoLab;
---

<Layout title={`${frontmatter.title} - Sanatorio San José`}>

  <section class="bg-slate-900 text-white py-20 px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(59,130,246,0.1),transparent_50%)]"></div>
    <div class="max-w-6xl mx-auto relative z-10">
      <span class="inline-block bg-blue-500/20 text-blue-300 px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider mb-4">
        Servicios Médicos
      </span>
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4">
        {frontmatter.title}
      </h1>
      <p class="text-lg text-slate-300 max-w-2xl leading-relaxed">
        {frontmatter.acreditacion}
      </p>
    </div>
  </section>

  <section class="bg-slate-50 py-16 px-6">
    <div class="max-w-6xl mx-auto">
      
      <div class="max-w-3xl mb-16">
        <article class="prose prose-slate max-w-none 
          prose-p:text-slate-600 prose-p:text-lg prose-p:leading-relaxed">
          <Content />
        </article>
        
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mt-6">
          Dirección Técnica: <span class="text-slate-700 font-bold normal-case ml-1">{frontmatter.direccion_tecnica}</span>
        </p>
      </div>

      <div class="mb-20">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          
          <div class="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm flex flex-col justify-between min-h-[120px]">
            <div>
              <span class="text-xs font-bold text-slate-400 uppercase tracking-wider block mb-2">🕒 Horario de Atención</span>
              <p class="text-xl font-bold text-slate-800 tracking-tight">
                {frontmatter.horarios.atencion}
              </p>
            </div>
          </div>

          <div class="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm flex flex-col justify-between min-h-[120px] relative overflow-hidden">
            <div class="absolute top-0 left-0 h-full w-1 bg-blue-600"></div>
            <div>
              <span class="text-xs font-bold text-blue-600 uppercase tracking-wider block mb-2">💉 Horario de Extracciones</span>
              <p class="text-xl font-extrabold text-slate-900 tracking-tight">
                {frontmatter.horarios.extracciones}
              </p>
            </div>
          </div>

        </div>
      </div>

      <div class="group/section mb-20">
        
        <div class="mb-10 flex items-center justify-between border-b border-slate-200 pb-5">
          <div>
            <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-slate-900 group-hover/section:text-blue-900 transition-colors duration-300">
              Especialidades Bioquímicas
            </h2>
            <p class="text-sm text-slate-500 mt-1">
              Análisis clínicos y de alta complejidad disponibles
            </p>
          </div>
          <div class="w-16 h-1 bg-blue-600 rounded-full group-hover/section:w-28 transition-all duration-500 ease-out"></div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-y-4 gap-x-8 pl-2">
          {frontmatter.especialidades.map((especialidad) => (
            <div class="flex items-center gap-3 py-1.5 border-b border-slate-200/40 sm:border-b-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-4 h-4 text-blue-600 shrink-0">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              <span class="text-slate-700 font-medium text-base md:text-lg tracking-tight">
                {especialidad}
              </span>
            </div>
          ))}
        </div>

      </div>

      <div class="bg-white rounded-2xl p-8 border border-slate-200 shadow-sm">
        <div class="mb-6 pb-4 border-b border-slate-100">
          <h3 class="text-xl font-bold text-slate-900">Central de Consultas y Autorizaciones</h3>
          <p class="text-slate-500 text-xs mt-0.5">Vías de comunicación directa con nuestro personal bioquímico</p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          
          <div class="flex flex-col gap-1">
            <span class="text-[11px] font-bold text-slate-400 uppercase tracking-wider">Llamadas</span>
            <span class="text-slate-700 text-sm font-semibold leading-relaxed">
              {frontmatter.contacto.telefono}
            </span>
          </div>

          <div class="flex flex-col gap-1">
            <span class="text-[11px] font-bold text-emerald-600 uppercase tracking-wider">WhatsApp</span>
            <a 
              href={frontmatter.contacto.whatsapp_link}
              target="_blank" 
              class="inline-flex items-center gap-1.5 text-emerald-600 font-bold hover:text-emerald-700 transition-colors text-sm"
            >
              💬 {frontmatter.contacto.whatsapp}
            </a>
          </div>

          <div class="flex flex-col gap-1">
            <span class="text-[11px] font-bold text-blue-600 uppercase tracking-wider">Correo Electrónico</span>
            <a 
              href={`mailto:${frontmatter.contacto.email}`}
              class="text-blue-600 font-semibold hover:text-blue-700 transition-colors text-sm truncate"
            >
              ✉️ {frontmatter.contacto.email}
            </a>
          </div>

        </div>
      </div>

    </div>
  </section>

</Layout>