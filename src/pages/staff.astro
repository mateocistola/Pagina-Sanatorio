---
import Layout from '../layouts/Layout.astro';
import profesionales from '../data/profesionales.json';
---

<Layout>

  <!-- Hero Section con fondo sólido de alto contraste -->
  <section class="bg-slate-900 text-white py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <span class="inline-block bg-blue-500/20 text-blue-300 px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider mb-4">
        Staff Médico
      </span>
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4">
        Profesionales y Especialidades
      </h1>
      <!-- Cambiado a texto gris claro para asegurar lectura sobre oscuro -->
      <p class="text-lg text-slate-300 max-w-2xl">
        Consultá el listado de profesionales y especialidades médicas del sanatorio.
      </p>
    </div>
  </section>

  <!-- Cuerpo de Especialidades -->
  <section class="bg-slate-50 py-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="space-y-16">

        {profesionales.map((especialidad) => (
          <div class="block">
            
            <!-- Título de Especialidad Separado -->
            <div class="border-b border-slate-200 pb-4 mb-8">
              <h2 class="text-2xl md:text-3xl font-bold text-slate-900">
                {especialidad.especialidad}
              </h2>
              <div class="w-16 h-1 bg-blue-600 mt-3 rounded"></div>
            </div>

            <!-- Grilla Forzada de Profesionales -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
              {especialidad.profesionales.map((profesional) => (
                <div class="bg-white rounded-xl p-5 border border-slate-200 shadow-sm flex flex-col justify-between min-h-[140px]">
                  
                  <div>
                    <!-- Nombre Destacado -->
                    <h3 class="text-xl font-bold text-slate-800 tracking-tight">
                      {profesional.nombre}
                    </h3>
                  </div>

                  <!-- Información de Matrícula al Pie -->
                  <div class="mt-4 pt-3 border-t border-slate-100 flex items-center justify-between">
                    <span class="text-xs font-medium text-slate-400 uppercase tracking-wider">Matrícula</span>
                    <span class="bg-slate-100 text-slate-700 text-xs font-semibold px-2.5 py-1 rounded-md">
                      {profesional.matricula}
                    </span>
                  </div>

                </div>
              ))}
            </div>

          </div>
        ))}

      </div>
    </div>
  </section>

</Layout>